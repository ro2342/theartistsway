<Page
    x:Class="ArtistWayUWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ArtistWayUWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!--
          O Button padrão do UWP tem um chrome arredondado/recuado no
          estado Pressed/PointerOver — fica parecendo um botão de app
          Android, não uma linha de lista nativa do Windows. Esse template
          simplificado faz o destaque preencher a linha inteira (mesmas
          brushes que ListViewItem usa pra seleção), sem cantos
          arredondados nem margem sobrando — usado tanto pelas linhas do
          painel de navegação quanto pelo botão hambúrguer.
        -->
        <Style x:Key="NavRowStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundListLowBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundListMediumBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Padding="{TemplateBinding Padding}"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão hambúrguer: quadrado sólido na cor de destaque, no canto
             superior-esquerdo do cabeçalho fixo, ao lado do título da seção
             atual — igual à barra de cima dos apps nativos da Microsoft
             (News, Forecast, Settings): hambúrguer + nome da seção sempre
             juntos no topo, não flutuando por cima do conteúdo. -->
        <Style x:Key="HamburgerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <!-- O cabeçalho (HeaderBar) fica FORA do SplitView, como irmão dele
         numa linha própria acima — assim ele nunca é coberto pelo painel
         deslizante (que só cobre a área abaixo, onde está o SplitView) e o
         hambúrguer continua sempre visível/clicável pra fechar o painel,
         mesmo com ele aberto. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho fixo: barra cinza no topo com hambúrguer + título da
             seção atual, sempre juntos (nunca some, mesmo com o painel
             aberto) — o HeaderTitleText troca de texto conforme a seção
             (Início/Jornada/Date/Recursos/Meu Perfil/Ajustes), em fonte
             pequena (não do tamanho de título de página), igual à barra
             "☰ msn sports" dos apps nativos da Microsoft. -->
        <Grid x:Name="HeaderBar" Grid.Row="0"
              Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="MenuButton"
                    Grid.Column="0"
                    Click="MenuButton_Click"
                    Style="{StaticResource HamburgerButtonStyle}">
                <!-- FontIcon com o glifo cru (Segoe MDL2 Assets) em vez de
                     SymbolIcon Symbol="GlobalNavigationButton" — esse
                     membro do enum Symbol não existe no runtime do
                     Windows 10 Mobile do Lumia (SDK do build é mais novo
                     que o sistema do aparelho), causava crash em tempo
                     de execução ("Failed to create a SymbolIcon from
                     the text 'GlobalNavigationButton'"). Glyph é só uma
                     string, sem contrato de API versionado por trás. -->
                <FontIcon Glyph="&#xE700;" />
            </Button>
            <TextBlock x:Name="HeaderTitleText"
                       Grid.Column="1"
                       Style="{StaticResource BodyTextBlockStyle}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="12,0,16,0" />
        </Grid>

        <SplitView x:Name="NavSplitView"
                   Grid.Row="1"
                   DisplayMode="Overlay"
                   PanePlacement="Left"
                   OpenPaneLength="248"
                   IsPaneOpen="False">
            <SplitView.Pane>
                <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,32,0,0">
                        <Button x:Name="NavHome" Tag="Home" Click="NavItem_Click" Style="{StaticResource NavRowStyle}">
                            <StackPanel Orientation="Horizontal">
                                <SymbolIcon x:Name="NavHomeIcon" Symbol="Home" />
                                <TextBlock x:Name="NavHomeLabel" Text="Início" Margin="20,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavProgress" Tag="Progress" Click="NavItem_Click" Style="{StaticResource NavRowStyle}">
                            <StackPanel Orientation="Horizontal">
                                <SymbolIcon x:Name="NavProgressIcon" Symbol="List" />
                                <TextBlock x:Name="NavProgressLabel" Text="Jornada" Margin="20,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavArtistDate" Tag="ArtistDate" Click="NavItem_Click" Style="{StaticResource NavRowStyle}">
                            <StackPanel Orientation="Horizontal">
                                <SymbolIcon x:Name="NavArtistDateIcon" Symbol="Favorite" />
                                <TextBlock x:Name="NavArtistDateLabel" Text="Date" Margin="20,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavFerramentas" Tag="Ferramentas" Click="NavItem_Click" Style="{StaticResource NavRowStyle}">
                            <StackPanel Orientation="Horizontal">
                                <SymbolIcon x:Name="NavFerramentasIcon" Symbol="Repair" />
                                <TextBlock x:Name="NavFerramentasLabel" Text="Recursos" Margin="20,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Itens utilitários, separados por uma linha que ocupa
                         a largura inteira do painel (sem margem lateral) —
                         Meu Perfil, Sincronizar e Ajustes ficam juntos aqui,
                         fora da lista principal de seções. -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <Border Height="1" Margin="0,0,0,8" Background="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                        <Button x:Name="NavProfile" Tag="Profile" Click="NavItem_Click" Style="{StaticResource NavRowStyle}">
                            <StackPanel Orientation="Horizontal">
                                <!-- FontIcon (glifo "Contact", Segoe MDL2 Assets)
                                     em vez de SymbolIcon: depois do crash do
                                     GlobalNavigationButton, ícone novo sempre
                                     como glifo cru, sem depender do enum Symbol. -->
                                <FontIcon x:Name="NavProfileIcon" Glyph="&#xE77B;" FontSize="16" />
                                <TextBlock x:Name="NavProfileLabel" Text="Meu Perfil" Margin="20,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSync" Click="SyncNowButton_Click" Style="{StaticResource NavRowStyle}">
                            <StackPanel Orientation="Horizontal">
                                <SymbolIcon Symbol="Sync" />
                                <TextBlock x:Name="NavSyncLabel" Text="Sincronizar" Margin="20,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSettings" Tag="Settings" Click="NavItem_Click" Style="{StaticResource NavRowStyle}">
                            <StackPanel Orientation="Horizontal">
                                <SymbolIcon x:Name="NavSettingsIcon" Symbol="Setting" />
                                <TextBlock x:Name="NavSettingsLabel" Text="Ajustes" Margin="20,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <Grid>
                    <Frame x:Name="ContentFrame" x:FieldModifier="public" />

                    <Border x:Name="ErrorPanel"
                            Visibility="Collapsed"
                            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                            Padding="20">
                        <TextBlock x:Name="ErrorText"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyTextBlockStyle}" />
                    </Border>

                    <!-- Fecha o painel ao tocar fora dele (light-dismiss manual
                         — SplitView não faz isso sozinho). -->
                    <Border x:Name="PaneDismissOverlay"
                            Background="Transparent"
                            Visibility="Collapsed"
                            Tapped="PaneDismissOverlay_Tapped" />
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>
