<Page
    x:Class="ArtistWayUWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ArtistWayUWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#E9E2D0">

    <Grid>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="20">
            <TextBlock Text="Build de diagnóstico (sem WebView)"
                       FontSize="24"
                       Foreground="#35301F"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Se você está vendo isso, o app abriu normalmente sem o WebView."
                       FontSize="16"
                       Foreground="#35301F"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0" />
        </StackPanel>
        <Border x:Name="ErrorPanel"
                Visibility="Collapsed"
                Background="#E9E2D0"
                Padding="20">
            <TextBlock x:Name="ErrorText"
                       TextWrapping="Wrap"
                       Foreground="#35301F"
                       FontSize="16" />
        </Border>
    </Grid>
</Page>
