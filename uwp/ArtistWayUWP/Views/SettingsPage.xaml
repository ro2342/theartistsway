<Page
    x:Class="ArtistWayUWP.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ArtistWayUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="16,16,16,24">
        <StackPanel>
            <TextBlock Text="Ajustes" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="seus rituais" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,4,0,16" />

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Seu perfil" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <TextBlock Text="Nome" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,12,0,4" />
                    <TextBox x:Name="NameBox" />

                    <TextBlock Text="Início da Semana 1" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,12,0,4" />
                    <DatePicker x:Name="StartDatePicker" HorizontalAlignment="Stretch" />

                    <TextBlock Text="Horário das Morning Pages" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,12,0,4" />
                    <TimePicker x:Name="MorningPagesTimePicker" HorizontalAlignment="Stretch" />

                    <TextBlock Text="Dia do Artist Date" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,12,0,4" />
                    <ComboBox x:Name="ArtistDateDayCombo" HorizontalAlignment="Stretch" />

                    <TextBlock Text="Horário do Artist Date" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,12,0,4" />
                    <TimePicker x:Name="ArtistDateTimePicker" HorizontalAlignment="Stretch" />

                    <TextBlock Text="Dia do check-in" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,12,0,4" />
                    <ComboBox x:Name="CheckinDayCombo" HorizontalAlignment="Stretch" />

                    <TextBlock Text="Horário do check-in" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" Margin="0,12,0,4" />
                    <TimePicker x:Name="CheckinTimePicker" HorizontalAlignment="Stretch" />

                    <Button Content="Salvar e reativar lembretes" Click="SaveProfile_Click" HorizontalAlignment="Stretch" Margin="0,16,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Calendário do Windows" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Adiciona o compromisso recorrente direto no app de Calendário do aparelho." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <Button Content="+ Morning Pages diário" Click="NativeCalMp_Click" HorizontalAlignment="Stretch" />
                    <Button Content="+ Artist Date semanal" Click="NativeCalAd_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                    <Button Content="+ Check-in semanal" Click="NativeCalCi_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Google Calendar" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Um toque adiciona o compromisso recorrente direto no seu calendário." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <Button Content="+ Morning Pages diário" Click="CalMp_Click" HorizontalAlignment="Stretch" />
                    <Button Content="+ Artist Date semanal" Click="CalAd_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                    <Button Content="+ Check-in semanal" Click="CalCi_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Seus dados" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Tudo fica só no seu aparelho. Faça backup de vez em quando." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <Button Content="Exportar backup (.json)" Click="Export_Click" HorizontalAlignment="Stretch" />
                    <Button Content="Importar backup (.json)" Click="Import_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Referência" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Sempre à mão, pra reler quando bater a dúvida." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <Button Content="Regras da Estrada" Click="OpenRoadRules_Click" HorizontalAlignment="Stretch" />
                    <Button Content="Princípios Básicos" Click="OpenPrinciples_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Atualizações" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="UpdateStatusText" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <Button x:Name="DownloadUpdateButton" Content="Baixar atualização" Visibility="Collapsed" Click="DownloadUpdate_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Sincronização (experimental)" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Login com Google guarda seu progresso na nuvem (Firebase). A sincronização de dados em si ainda está sendo construída -- por enquanto isso mantém você logado nesse aparelho."
                               Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <TextBlock x:Name="SyncStatusText" Text="Não logado." Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Button x:Name="GoogleLoginButton" Content="Entrar com Google" Click="GoogleLogin_Click" HorizontalAlignment="Stretch" />
                    <Button x:Name="SignOutButton" Content="Sair" Click="SignOut_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" Visibility="Collapsed" />
                    <Button Content="Mostrar identificador do pacote" Click="ShowPackageSid_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                    <Button Content="Testar login com Microsoft (pausado)" Click="TestMicrosoftLogin_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Zona de risco" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Apaga todo o progresso salvo no aparelho (perfil, Morning Pages, Artist Dates, checklist, check-ins) e volta pro começo. Não tem como desfazer -- faça um backup antes se quiser guardar alguma coisa."
                               Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <Button Content="Resetar o app" Click="Reset_Click" HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
