<Page
    x:Class="ArtistWayUWP.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ArtistWayUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Faixa cinza atrás do cabeçalho de abas do Pivot (mesma brush da
             HeaderBar do shell), pra continuar a barra cinza que já vem
             do título "Ajustes" — igual ao Settings nativo da Microsoft,
             onde a barra de trás do título e das abas é uma coisa só. -->
        <Border VerticalAlignment="Top" Height="48"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" />

        <Pivot x:Name="SettingsPivot">
            <PivotItem x:Name="AppearanceTab" Header="Aparência">
                <ScrollViewer Padding="16,12,16,24">
                    <StackPanel>
                        <TextBlock x:Name="AppearanceDescriptionText"
                                   Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ThemeLightButton" Content="Claro" Tag="light" Click="ThemeMode_Click"
                                    Grid.Column="0" HorizontalAlignment="Stretch" Margin="0,0,4,0" />
                            <Button x:Name="ThemeDarkButton" Content="Escuro" Tag="dark" Click="ThemeMode_Click"
                                    Grid.Column="1" HorizontalAlignment="Stretch" Margin="4,0,4,0" />
                            <Button x:Name="ThemeAutoButton" Content="Auto" Tag="auto" Click="ThemeMode_Click"
                                    Grid.Column="2" HorizontalAlignment="Stretch" Margin="4,0,0,0" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <PivotItem x:Name="DataSyncTab" Header="Dados &amp; Sync">
                <ScrollViewer Padding="16,12,16,24">
                    <StackPanel>
                        <TextBlock x:Name="DataTitleText" Text="Seus dados" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Tudo fica só no seu aparelho. Faça backup de vez em quando." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                        <Button Content="Exportar backup (.json)" Click="Export_Click" HorizontalAlignment="Stretch" />
                        <Button Content="Importar backup (.json)" Click="Import_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" />

                        <Border Style="{StaticResource SectionDividerStyle}" />

                        <TextBlock x:Name="SyncTitleText" Text="Sincronização" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Login com Google sincroniza seu progresso entre aparelhos automaticamente em segundo plano — funciona junto com o PWA, no mesmo login."
                                   Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                        <TextBlock x:Name="SyncStatusText" Text="Não logado." Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <Button x:Name="GoogleLoginButton" Content="Entrar com Google" Click="GoogleLogin_Click" HorizontalAlignment="Stretch" />
                        <Button x:Name="SignOutButton" Content="Sair" Click="SignOut_Click" HorizontalAlignment="Stretch" Margin="0,8,0,0" Visibility="Collapsed" />
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <PivotItem x:Name="AdvancedTab" Header="Avançado">
                <ScrollViewer Padding="16,12,16,24">
                    <StackPanel>
                        <TextBlock x:Name="UpdatesTitleText" Text="Atualizações" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="UpdateStatusText" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,0" />
                        <ProgressBar x:Name="UpdateProgressBar" Minimum="0" Maximum="100" Visibility="Collapsed" Margin="0,12,0,0" />
                        <Button x:Name="DownloadUpdateButton" Content="Baixar atualização" Visibility="Collapsed" Click="DownloadUpdate_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                        <Button x:Name="InstallUpdateButton" Content="Instalar agora" Visibility="Collapsed" Click="InstallUpdate_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0" />

                        <Border Style="{StaticResource SectionDividerStyle}" />

                        <TextBlock x:Name="MaintenanceTitleText" Text="Modo manutenção" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Depois das 12 semanas, desliga o checklist e o check-in semanal — fica só Morning Pages e Artist Date rodando indefinidamente."
                                   Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                        <Button x:Name="ToggleMaintenanceButton" Content="Ativar modo manutenção" Click="ToggleMaintenance_Click" HorizontalAlignment="Stretch" />

                        <Border Style="{StaticResource SectionDividerStyle}" />

                        <TextBlock x:Name="DangerZoneTitleText" Text="Zona de risco" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Apaga o progresso salvo (perfil, Morning Pages, Artist Dates, checklist, check-ins). Não tem como desfazer — faça um backup antes se quiser guardar alguma coisa."
                                   Style="{StaticResource BodyTextBlockStyle}" Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,12" />
                        <Button Click="ClearData_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                            <TextBlock Text="Apagar todos os dados (mantém login)" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <Button Click="FullReset_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,8,0,0">
                            <TextBlock Text="Resetar o app completamente (sai da conta)" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
