<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  IgnorableNamespaces="uap mp">

  <Identity
    Name="RodCarvalho.ArtistWayCompanion"
    Publisher="CN=RodCarvalho-ArtistWay-SelfSigned"
    Version="2.0.0.7" />

  <mp:PhoneIdentity PhoneProductId="a3d5c6d1-8b1a-4e0a-9a3f-3f2b6e0a7c11" PhonePublisherId="00000000-0000-0000-0000-000000000000" />

  <Properties>
    <DisplayName>Artist's Way</DisplayName>
    <PublisherDisplayName>Rod Carvalho</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <!--
      MinVersion/MaxVersionTested aqui são placeholders: o MSBuild reescreve
      esses dois valores automaticamente a partir de TargetPlatformMinVersion
      e TargetPlatformVersion do arquivo .csproj no momento do build.
      O Name="Windows.Mobile" é o que importa e fica como está.
    -->
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.14393.0" MaxVersionTested="10.0.17763.0" />
  </Dependencies>

  <Resources>
    <Resource Language="pt-BR" />
  </Resources>

  <Applications>
    <Application Id="App" Executable="$targetnametoken$.exe" EntryPoint="ArtistWayUWP.App">
      <uap:VisualElements
        DisplayName="Artist's Way"
        Description="Companheiro de leitura para The Artist's Way — checklist, Morning Pages e Artist Date."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          Square71x71Logo="Assets\Square71x71Logo.png">
          <uap:ShowNameOnTiles>
            <uap:ShowOn Tile="square150x150Logo" />
            <uap:ShowOn Tile="wide310x150Logo" />
          </uap:ShowNameOnTiles>
        </uap:DefaultTile>
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="transparent" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <!--
      Exigida por AppointmentManager.ShowAddAppointmentAsync (o botão
      "Calendário do Windows"). A doc da Microsoft cita "appointmentsSystem",
      mas o schema real do manifesto só aceita "appointments" (conferido
      pelo erro APPX0501 do primeiro build depois de declarar errado).
    -->
    <uap:Capability Name="appointments" />
  </Capabilities>

</Package>
